# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Server Port
PORT=3000

# JWT Secret for authentication
JWT_SECRET="educart_secret_key_change_in_production_2024"

# Master Admin Setup (Seeded in migrations and fallback JSON automatically)
ADMIN_NAME="Administrador Master"
ADMIN_EMAIL="admin@educart.com.br"
ADMIN_PASSWORD="change_this_password_123"

# Database Configuration (MySQL)
# When running with Docker Compose, DB_HOST should be the service name 'db'
DB_HOST="db"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="12345678"
DB_NAME="educart"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# ========================================================
# Supabase Configuration (for Image Uploads / Storage)
# ========================================================
# Certifique-se de criar um bucket público chamado 'imagens-educarte' no seu Supabase Storage.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ========================================================
# Nixpacks / Easypanel Configuration
# ========================================================
# Este projeto utiliza Nixpacks para build em ambientes como Easypanel ou Coolify.
# O Nixpacks detecta e constrói o app automaticamente como um projeto Node.js de
# tipo "module" (ESM). No Easypanel, você pode configurar as variáveis acima 
# no painel de Environment Variables do serviço.
#
# Caso precise forçar versões de node/npm, declare no package.json ou use:
# NIXPACKS_NODE_VERSION=20
# ========================================================
